generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Plan {
  FREE
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  plan         Plan     @default(FREE)
  locale       String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Stripe billing
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?

  // Daily "France opportunity radar" email digest
  digestEnabled    Boolean   @default(false)
  digestKeywords   String[]  @default([])
  digestLastSentAt DateTime?

  @@index([stripeCustomerId])
  @@index([digestEnabled])

  sessions     Session[]
  searches     SearchLog[]
  savedItems   SavedItem[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Cache of LLM translations to avoid re-translating identical source strings.
// `id` = sha1(target + source); news titles are immutable so entries never go
// stale. Saves tokens since the same headlines are viewed by many users.
model Translation {
  id        String   @id
  target    String
  text      String
  createdAt DateTime @default(now())
}

// Single-use password-reset tokens. `id` stores sha256(token); the raw token
// only ever lives in the emailed link.
model PasswordResetToken {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Usage tracking for quota enforcement (Free = 10 searches/day)
model SearchLog {
  id        String   @id @default(cuid())
  userId    String
  module    String
  query     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum ItemType {
  COMPANY
  TENDER
  OPPORTUNITY
  CONTACT
}

// Value-added service inquiries (company / brand registration lead capture).
enum LeadKind {
  COMPANY
  BRAND
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  WON
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  kind      LeadKind   @default(OTHER)
  name      String
  email     String
  company   String?
  message   String?
  locale    String     @default("en")
  status    LeadStatus @default(NEW)
  userId    String? // set when submitted by a logged-in user
  userEmail String? // snapshot of the submitter's account email, if any
  createdAt DateTime   @default(now())

  @@index([status, createdAt])
}

// Knowledge OS L3 — Playbooks persisted with version history. `data` holds the
// full localized RawPlaybook JSON; every content change snapshots a version.
model Playbook {
  id          String            @id @default(cuid())
  slug        String            @unique
  version     String
  contentHash String
  data        Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt @default(now())
  versions    PlaybookVersion[]
}

model PlaybookVersion {
  id         String   @id @default(cuid())
  playbookId String
  version    String
  data       Json
  note       String?
  createdAt  DateTime @default(now())
  playbook   Playbook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([playbookId, createdAt])
}

// Knowledge OS L1 — raw documents, versioned and never overwritten. Same
// url+content (checksum) is deduped; changed content creates a new version and
// supersedes the old. Text content is stored inline (migrates with pg_dump);
// large/binary objects go to object storage via `storageKey`.
enum RawDocStatus {
  ACTIVE
  SUPERSEDED
}

model RawDocument {
  id         String       @id @default(cuid())
  source     String
  url        String
  lang       String?
  docType    String?
  checksum   String
  version    Int          @default(1)
  status     RawDocStatus @default(ACTIVE)
  storageKey String? // object-storage key when stored externally
  content    String? // inline text content (keyless default)
  meta       Json?
  fetchedAt  DateTime     @default(now())

  @@unique([url, checksum])
  @@index([source, fetchedAt])
  @@index([url])
}

// Knowledge OS L2 — semantic chunks (pgvector) + knowledge graph.
model DocChunk {
  id        String                       @id @default(cuid())
  rawDocId  String
  source    String?
  url       String?
  ord       Int
  text      String
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())

  @@index([rawDocId])
}

enum KnowledgeStatus {
  CANDIDATE
  APPROVED
  REJECTED
}

model KnowledgeNode {
  id         String          @id @default(cuid())
  type       String // Authority / Permit / Regulation / Document / Region / Industry …
  name       String
  props      Json?
  confidence Float           @default(0)
  sourceRef  String? // url or rawDocId — every node is traceable
  status     KnowledgeStatus @default(CANDIDATE)
  version    Int             @default(1)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt @default(now())
  fromEdges  KnowledgeEdge[] @relation("fromNode")
  toEdges    KnowledgeEdge[] @relation("toNode")

  @@unique([type, name])
  @@index([status])
}

model KnowledgeEdge {
  id         String          @id @default(cuid())
  fromId     String
  toId       String
  relation   String // requires / issued_by / managed_by / depends_on / applicable_to …
  confidence Float           @default(0)
  sourceRef  String?
  status     KnowledgeStatus @default(CANDIDATE)
  createdAt  DateTime        @default(now())
  from       KnowledgeNode   @relation("fromNode", fields: [fromId], references: [id], onDelete: Cascade)
  to         KnowledgeNode   @relation("toNode", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relation])
  @@index([status])
}

// Knowledge OS L4 — real-project execution knowledge. Each customer project
// (optionally following a Playbook) accumulates steps with actual durations,
// costs, problems and lessons. History is never overwritten; aggregate stats
// feed "Experience Intelligence".
enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

model Project {
  id           String        @id @default(cuid())
  title        String
  playbookSlug String? // links to a Playbook
  sector       String?
  region       String?
  status       ProjectStatus @default(PLANNING)
  startedAt    DateTime?
  completedAt  DateTime?
  actualDays   Int?
  actualCostEur Int?
  partners     String[]      @default([])
  notes        String?
  ownerId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt @default(now())
  steps        ProjectStep[]

  @@index([playbookSlug, status])
}

model ProjectStep {
  id          String     @id @default(cuid())
  projectId   String
  name        String
  status      StepStatus @default(PENDING)
  actualDays  Int?
  approvalDays Int?
  authority   String?
  partner     String?
  problem     String?
  solution    String?
  lessons     String?
  createdAt   DateTime   @default(now())
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Audit/event stream surfaced in the admin console.
enum EventType {
  USER_REGISTERED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  SUBSCRIPTION_CANCELED
  LEAD_CREATED
}

model Event {
  id        String    @id @default(cuid())
  type      EventType
  userId    String?
  email     String?
  meta      Json?
  createdAt DateTime  @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}

// Lightweight CRM pipeline stages for saved/watched items.
enum Stage {
  LEAD
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

// Bookmarked/saved entities across modules (the watchlist / light CRM).
model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  type      ItemType
  refId     String
  label     String
  data      Json
  note      String?
  stage     Stage    @default(LEAD)
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, refId])
  @@index([userId, stage])
}
