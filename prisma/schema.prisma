generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  plan         Plan     @default(FREE)
  locale       String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Stripe billing
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  currentPeriodEnd     DateTime?

  @@index([stripeCustomerId])

  sessions     Session[]
  searches     SearchLog[]
  savedItems   SavedItem[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Cache of LLM translations to avoid re-translating identical source strings.
// `id` = sha1(target + source); news titles are immutable so entries never go
// stale. Saves tokens since the same headlines are viewed by many users.
model Translation {
  id        String   @id
  target    String
  text      String
  createdAt DateTime @default(now())
}

// Single-use password-reset tokens. `id` stores sha256(token); the raw token
// only ever lives in the emailed link.
model PasswordResetToken {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Usage tracking for quota enforcement (Free = 10 searches/day)
model SearchLog {
  id        String   @id @default(cuid())
  userId    String
  module    String
  query     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum ItemType {
  COMPANY
  TENDER
  OPPORTUNITY
  CONTACT
}

// Value-added service inquiries (company / brand registration lead capture).
enum LeadKind {
  COMPANY
  BRAND
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  WON
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  kind      LeadKind   @default(OTHER)
  name      String
  email     String
  company   String?
  message   String?
  locale    String     @default("en")
  status    LeadStatus @default(NEW)
  userId    String? // set when submitted by a logged-in user
  userEmail String? // snapshot of the submitter's account email, if any
  createdAt DateTime   @default(now())

  @@index([status, createdAt])
}

// Audit/event stream surfaced in the admin console.
enum EventType {
  USER_REGISTERED
  PLAN_UPGRADED
  PLAN_DOWNGRADED
  SUBSCRIPTION_CANCELED
  LEAD_CREATED
}

model Event {
  id        String    @id @default(cuid())
  type      EventType
  userId    String?
  email     String?
  meta      Json?
  createdAt DateTime  @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}

// Lightweight CRM pipeline stages for saved/watched items.
enum Stage {
  LEAD
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

// Bookmarked/saved entities across modules (the watchlist / light CRM).
model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  type      ItemType
  refId     String
  label     String
  data      Json
  note      String?
  stage     Stage    @default(LEAD)
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, refId])
  @@index([userId, stage])
}
