# ---- Production env template (copy to .env on the server, fill in real values) ----
# Domain: infr.europeanaialliance.org

NODE_ENV="production"

# App
NEXT_PUBLIC_APP_URL="https://infr.europeanaialliance.org"
# Port the Next server listens on — MUST match ecosystem.config.cjs and the
# CloudPanel reverse-proxy target. Pick a free port (not used by other sites).
PORT="3011"

# Database — reuse the existing PostgreSQL on the VPS, with a NEW dedicated db+user.
# Replace USER / PASSWORD / PORT / DBNAME accordingly.
DATABASE_URL="postgresql://france_os:CHANGE_ME@127.0.0.1:5432/france_os?schema=public"

# Auth — generate a long random string, e.g. `openssl rand -hex 32`
SESSION_SECRET="CHANGE_ME_to_a_64_char_random_hex_string"

# ===== AI / LLM (online provider) =====
AI_MOCK="false"
# deepseek | openai | qwen | claude
AI_PROVIDER="deepseek"
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
QWEN_API_KEY=""
QWEN_MODEL="qwen-plus"
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-8"

# Public data APIs (keyless)
RECHERCHE_ENTREPRISES_API="https://recherche-entreprises.api.gouv.fr"
BOAMP_API="https://boamp-datadila.opendatasoft.com/api/explore/v2.1"
TED_API="https://api.ted.europa.eu/v3"

# Value-added service CTA links (company / brand registration partners).
# Leave blank => button is a placeholder (#). Set to your partner URL or mailto.
NEXT_PUBLIC_PARTNER_URL=""
NEXT_PUBLIC_PARTNER_COMPANY_URL=""
NEXT_PUBLIC_PARTNER_BRAND_URL=""

# Optional richer sources (leave blank to use fallbacks)
PAPPERS_API_KEY=""
INPI_USERNAME=""
INPI_PASSWORD=""
EUIPO_CLIENT_ID=""
EUIPO_CLIENT_SECRET=""
